# =============================================================
# The Naminator - Environment Variables
# Copy this file to .env and fill in your values
# =============================================================

# --- Database (Neon PostgreSQL) ---
# Sign up at https://neon.tech and create a project.
# Copy the connection string from your Neon dashboard.
DATABASE_URL=""

# --- Auth.js ---
# Generate a secret: openssl rand -base64 32
AUTH_SECRET=""

# The base URL of your app (no trailing slash)
AUTH_URL=""

# --- Google OAuth ---
# Create credentials at https://console.cloud.google.com/apis/credentials
# 1. Create a new OAuth 2.0 Client ID
# 2. Set Authorized redirect URI to: http://localhost:3000/api/auth/callback/google
AUTH_GOOGLE_ID=""
AUTH_GOOGLE_SECRET=""

# --- Anthropic API ---
# Get your API key at https://console.anthropic.com/
ANTHROPIC_API_KEY=""
